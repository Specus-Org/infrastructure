# =============================================================================
# Specus Infrastructure Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# Generate secrets with the commands shown in comments
# =============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_generate_with_openssl_rand_base64_32
POSTGRES_DB=specus

# Application Database Role
SPECUS_APP_PASSWORD=change_me_generate_with_openssl_rand_base64_32

# Airflow Database (user created by init script)
AIRFLOW_DB_PASSWORD=change_me_generate_with_openssl_rand_base64_32

# Airflow Security
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=change_me_generate_fernet_key

# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__API__SECRET_KEY=change_me_generate_secret_key

# Airflow Admin User
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_use_strong_password

# Redis (if using CeleryExecutor)
REDIS_PASSWORD=change_me_generate_with_openssl_rand_base64_32
