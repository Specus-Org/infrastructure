# =============================================================================
# Specus Garage Environment Variables
# =============================================================================
# Copy to .env and fill in the values before deploying docker-compose.yml.
#
# Generate hex secrets:   openssl rand -hex 32
# Generate bcrypt hash:   htpasswd -nbBC 10 "admin" "your-password"
# =============================================================================

# ── Garage ──────────────────────────────────────────────────────────────────

# RPC secret for cluster node communication (required)
GARAGE_RPC_SECRET=change_me_generate_with_openssl_rand_hex_32

# Admin API token (required for bucket/key management)
GARAGE_ADMIN_TOKEN=change_me_generate_with_openssl_rand_hex_32

# Metrics endpoint token (optional, for Prometheus scraping)
GARAGE_METRICS_TOKEN=change_me_generate_with_openssl_rand_hex_32

# ── Garage WebUI ────────────────────────────────────────────────────────────

# Garage admin API endpoint (compose service name)
API_BASE_URL=http://garage:3903

# Admin API token (same value as GARAGE_ADMIN_TOKEN above)
API_ADMIN_KEY=change_me_same_as_garage_admin_token

# Garage S3 API endpoint (compose service name)
S3_ENDPOINT_URL=http://garage:3900

# S3 region (must match garage.toml s3_region)
S3_REGION=garage

# Basic auth for the WebUI (format: username:bcrypt_hash)
# Generate: htpasswd -nbBC 10 "admin" "your-password"
AUTH_USER_PASS=admin:change_me_generate_bcrypt_hash
