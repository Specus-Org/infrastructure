# wg-easy v15 initial credentials
# These are only used on first container startup, then stored in the DB.
# Remove INIT_* vars from .env after first login for security.
#
# To reset password later (INIT_* vars are ignored after first startup):
#   docker compose -f /opt/specus/wg-easy/docker-compose.yml exec wg-easy cli db:admin:reset --password 'NEW_PASSWORD'
#
# HTTPS access (optional):
#   setup-vps.sh can configure a domain (e.g. vpn.specus.id) via Traefik.
#   Requires a DNS A record pointing to the server IP and Dokploy's Traefik running.
#   See wg-easy/traefik-dynamic.yml.tpl for the Traefik config template.
INIT_ENABLED=true
INIT_USERNAME=admin
INIT_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
INIT_HOST=YOUR_SERVER_IP_OR_DOMAIN
INIT_PORT=51820
INIT_DNS=1.1.1.1
INIT_IPV4_CIDR=10.8.0.0/24
INIT_ALLOWED_IPS=10.8.0.0/24
