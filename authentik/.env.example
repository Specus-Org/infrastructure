# =============================================================================
# Specus Authentik Environment Variables
# =============================================================================
# Copy to .env and fill in the values.
# Generate passwords: openssl rand -base64 32
# Generate secret key: openssl rand -hex 32
# =============================================================================

# ── PostgreSQL (used by init-db.sh) ─────────────────────────────────────────

# Password for the authentik database role
AUTHENTIK_DB_PASSWORD=change_me_generate_with_openssl_rand_base64_32

# ── Authentik Server ────────────────────────────────────────────────────────

# PostgreSQL connection
AUTHENTIK_POSTGRESQL__HOST=specus-postgres
AUTHENTIK_POSTGRESQL__PORT=5432
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=change_me_same_as_authentik_db_password

# Redis connection (shared with other services)
AUTHENTIK_REDIS__HOST=specus-redis
AUTHENTIK_REDIS__PORT=6379
AUTHENTIK_REDIS__PASSWORD=change_me_same_as_redis_password

# Secret key for signing cookies and tokens (required)
AUTHENTIK_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
