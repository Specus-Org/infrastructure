# =============================================================================
# AUTHENTIK IDENTITY PROVIDER CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env file to git (it contains sensitive data)
#
# Usage: docker-compose --env-file .env up -d
# =============================================================================

# =============================================================================
# CORE CONFIGURATION (REQUIRED)
# =============================================================================

# Secret key for encryption - CRITICAL, keep safe!
# Generate with: openssl rand -base64 60 | tr -d '\n'
AUTHENTIK_SECRET_KEY=

# Authentik version (pinned for reproducibility)
AUTHENTIK_VERSION=2026.2.1

# Domain for Authentik UI (must match Traefik route)
AUTHENTIK_DOMAIN=auth.specus.org

# =============================================================================
# BOOTSTRAP CREDENTIALS (REQUIRED for first deployment)
# =============================================================================
# These create the initial admin account on first startup
# After first login, you can change the password and disable these

# Initial admin password
# Generate with: openssl rand -base64 32
AUTHENTIK_BOOTSTRAP_PASSWORD=

# API token for initial setup automation (optional but recommended)
# Generate with: openssl rand -base64 32
AUTHENTIK_BOOTSTRAP_TOKEN=

# Admin email address
AUTHENTIK_BOOTSTRAP_EMAIL=admin@specus.org

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Uses PostgreSQL from core stack

POSTGRES_HOST=specus-postgres
POSTGRES_PORT=5432
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=authentik_user

# Database password - must match what was set in init-authentik.sql
# Generate with: openssl rand -base64 32
AUTHENTIK_DB_PASSWORD=

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Uses Redis from core stack (DB 1 reserved for Authentik)

REDIS_HOST=specus-redis
REDIS_PORT=6379
AUTHENTIK_REDIS_DB=1

# Must match REDIS_PASSWORD from core stack
REDIS_PASSWORD=

# =============================================================================
# S3 STORAGE CONFIGURATION (Garage)
# =============================================================================
# Media files (avatars, branding) stored on Garage S3

AUTHENTIK_S3_ENDPOINT=https://storage.specus.org
AUTHENTIK_S3_BUCKET=authentik
AUTHENTIK_S3_REGION=garage

# S3 credentials (from: garage key create authentik-key)
AUTHENTIK_S3_ACCESS_KEY=
AUTHENTIK_S3_SECRET_KEY=

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# Needed for: password reset, email verification, notifications

AUTHENTIK_EMAIL_HOST=smtp.gmail.com
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USE_TLS=true

# For Gmail, use an App Password
AUTHENTIK_EMAIL_USERNAME=noreply@specus.org
AUTHENTIK_EMAIL_PASSWORD=

# Sender email
AUTHENTIK_EMAIL_FROM=noreply@specus.org

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Enable error reporting to Authentik (default: false)
AUTHENTIK_ERROR_REPORTING=false

# Enable Prometheus metrics endpoint (default: true)
AUTHENTIK_METRICS_ENABLED=true

# =============================================================================
# GENERATION COMMANDS
# =============================================================================
# Run these to generate secure values:
#
# AUTHENTIK_SECRET_KEY:
#   openssl rand -base64 60 | tr -d '\n'
#
# AUTHENTIK_BOOTSTRAP_PASSWORD:
#   openssl rand -base64 32
#
# AUTHENTIK_BOOTSTRAP_TOKEN:
#   openssl rand -base64 32
#
# AUTHENTIK_DB_PASSWORD:
#   openssl rand -base64 32
#
# =============================================================================
