# =============================================================================
# Specus PostgreSQL Environment Variables
# =============================================================================
# Copy to .env and fill in the values
# Generate passwords: openssl rand -base64 32
# =============================================================================

# Superuser credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_generate_with_openssl_rand_base64_32
POSTGRES_DB=specus

# Application role (used by backend services)
SPECUS_APP_PASSWORD=change_me_generate_with_openssl_rand_base64_32

# Airflow metadata role (used by Airflow scheduler/api-server)
AIRFLOW_DB_PASSWORD=change_me_generate_with_openssl_rand_base64_32

# Authentik identity provider role (owns its database for Django migrations)
AUTHENTIK_DB_PASSWORD=change_me_generate_with_openssl_rand_base64_32
