# =============================================================================
# APACHE SUPERSET CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env file to git (it contains sensitive data)
#
# Usage: docker-compose --env-file .env up -d
# First deploy: see bootstrap.md
# =============================================================================

# =============================================================================
# CORE CONFIGURATION (REQUIRED)
# =============================================================================

# Secret key for session signing and encryption - CRITICAL, keep safe!
# Rotating this value breaks decryption of stored data-source passwords
# in the metadata DB. See bootstrap.md § Rotating SUPERSET_SECRET_KEY.
# Generate with: openssl rand -base64 42
SUPERSET_SECRET_KEY=

# Superset image version (pinned for reproducibility)
# Uses upstream apache/superset directly — check latest stable at:
# https://hub.docker.com/r/apache/superset/tags
SUPERSET_VERSION=4.1.2

# Public domain for the Superset UI (must match Traefik route in Dokploy)
SUPERSET_DOMAIN=superset.specus.biz

# Number of Gunicorn workers in the web container. Kept low so the shared
# Postgres connection budget (max_connections=50) isn't exhausted when
# Airflow and Authentik are also active. See superset_config.py pool sizing.
SUPERSET_WEB_WORKERS=4

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Uses PostgreSQL from core stack (specus-production-database-rkpsij)
# Run init-superset.sql before first deploy.
#
# POSTGRES_HOST/PORT are shared across services (Airflow, Authentik, Superset);
# SUPERSET_DB_* are Superset-specific and must not collide with other services.

POSTGRES_HOST=specus-production-database-rkpsij
POSTGRES_PORT=5432
SUPERSET_DB_NAME=superset
SUPERSET_DB_USER=superset_user

# Must match the password set in init-superset.sql.
# Generate with: openssl rand -base64 32
SUPERSET_DB_PASSWORD=

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# Uses Redis from core stack (specus-production-redis-h08jhy).
# Redis DB allocation is documented centrally in README.md § Redis DB Allocation.
# Do not change these numbers without updating the README.

REDIS_HOST=specus-production-redis-h08jhy
REDIS_PORT=6379
SUPERSET_CACHE_REDIS_DB=2
SUPERSET_CELERY_BROKER_DB=3
SUPERSET_CELERY_RESULT_DB=4

# Must match REDIS_PASSWORD from core stack.
REDIS_PASSWORD=

# =============================================================================
# OPTIONAL OVERRIDES
# =============================================================================

# Override Superset's internal self-reference URL used by the worker for
# thumbnail rendering (default: http://superset-web:8088/ - matches compose hostname)
# SUPERSET_WEBDRIVER_BASEURL=http://superset-web:8088/

# =============================================================================
# GENERATION COMMANDS
# =============================================================================
#
# SUPERSET_SECRET_KEY:
#   openssl rand -base64 42
#
# SUPERSET_DB_PASSWORD:
#   openssl rand -base64 32
#
# =============================================================================
# ADMIN BOOTSTRAP (NOT read by containers — operator reference only)
# =============================================================================
# These values are supplied interactively during bootstrap.md Step 4 via
# stdin, not read from .env. They are listed here so the operator can
# generate + stash them alongside other secrets, then clear them from .env
# after the admin is created.
#
# SUPERSET_ADMIN_USERNAME=admin
# SUPERSET_ADMIN_EMAIL=admin@specus.biz
# SUPERSET_ADMIN_FIRSTNAME=Admin
# SUPERSET_ADMIN_LASTNAME=User
# SUPERSET_ADMIN_PASSWORD=<openssl rand -base64 32>
#
# =============================================================================
